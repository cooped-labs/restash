{
  "name": "restash",
  "version": "1.2.0",
  "description": "Cross-platform (macOS / Windows / Linux) app for saving and re-pasting items",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "brand": "node scripts/build-brand-assets.js",
    "lint:noinstall": "node scripts/lint-no-banned-tools.js",
    "typecheck": "node scripts/lint-no-banned-tools.js && node --check main.js",
    "pack": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "Restash",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "qrcode": "1.5.4",
    "zxing-wasm": "^1.3.4",
    "jsqr": "^1.4.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/notarize": "2.5.0",
    "electron": "33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.restash.app",
    "productName": "Restash",
    "copyright": "\u00a9 2026 Restash",
    "afterPack": "build/afterpack-sign.js",
    "afterSign": "build/notarize.js",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "stash-edit.html",
      "stash-edit-renderer.js",
      "stash-edit-preload.js",
      "qr-scan-overlay.html",
      "qr-scan-overlay-preload.js",
      "tutorial-preload.js",
      "onboarding-fullscreen.html",
      "platform/**/*",
      "assets/**/*",
      "node_modules/zxing-wasm/**/*",
      "node_modules/jsqr/**/*",
      "bin/restash-share",
      "bin/restash-clip-file",
      "bin/restash-read-clip-files",
      "bin/restash-decode-qr",
      "bin/restash-windows",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "publish": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSAccessibilityUsageDescription": "Restash needs Accessibility access to paste saved items into the app you're using.",
        "NSAppleEventsUsageDescription": "Restash uses AppleEvents to paste into the app you're using."
      }
    },
    "dmg": {
      "title": "Restash ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin/restash-win-helper.exe",
          "to": "bin/restash-win-helper.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "Restash"
      },
      "extraResources": [
        {
          "from": "bin/restash-linux-helper",
          "to": "bin/restash-linux-helper"
        },
        {
          "from": "vendor/linux-lib",
          "to": "lib",
          "filter": [
            "**/*.so*"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cooped-labs",
        "repo": "restash"
      }
    ]
  }
}
